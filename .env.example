# IoTSentinel Environment Configuration
# Copy to .env and fill in values. NEVER commit .env to version control.

MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=8883
MQTT_USERNAME=iotsentinel_monitor
MQTT_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
MQTT_CA_CERT=certs/ca.crt
MQTT_CLIENT_CERT=certs/client.crt
MQTT_CLIENT_KEY=certs/client.key

# Detection tuning
ZSCORE_THRESHOLD=3.0
IQR_MULTIPLIER=1.5
BASELINE_WINDOW=60
MIN_SAMPLES=10

# Alerting
ALERT_LOG_FILE=logs/alerts.jsonl
MIN_ALERT_SEVERITY=MEDIUM
# ALERT_WEBHOOK_URL=https://hooks.slack.com/your-webhook
